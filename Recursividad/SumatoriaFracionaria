import java.util.Scanner;

public class Punto3 {
    static double suma(int n) {
        if (n == 1) return 1;
        return (1.0 / n) + suma(n - 1);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        System.out.println(suma(n));
    }
}