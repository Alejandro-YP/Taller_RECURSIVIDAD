import java.util.Scanner;

public class Punto5 {
    static int suma(int n) {
        if (n == 0) return 0;
        return n + suma(n - 1);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        System.out.println(suma(n));
    }
}